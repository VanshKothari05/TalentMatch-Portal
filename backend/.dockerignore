*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments - never copy these into Docker
venv/
env/
.venv/
ENV/

# Dev/editor files
.env
.env.*
*.log
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Git
.git/
.gitignore